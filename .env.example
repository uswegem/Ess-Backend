# Server
PORT=3008
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ess

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# FSP (legacy single-tenant defaults)
FSP_NAME=ZE DONE
FSP_CODE=FL8090

# Multi-tenancy (Milestone 3)
TENANT_SECRET_ENCRYPTION_KEY=
LEGACY_TENANT_ID=legacy-zedone
TENANT_ENFORCEMENT=false

# ESS / Utumishi (outgoing XML callbacks to external ESS)
UTUMISHI_ENDPOINT=
API_TIMEOUT=30000

# CBS / MIFOS
CBS_BASE_URL=
CBS_Tenant=
CBS_MAKER_USERNAME=
CBS_MAKER_PASSWORD=
CBS_CHECKER_PASSWORD=
CBS_TIMEOUT_MS=30000
# Local dev only — skip live MIFOS auth check when activating tenants
SKIP_MIFOS_ACTIVATION_CHECK=false

# Certificates
PRIVATE_KEY_PATH=
CERTIFICATE_PATH=
